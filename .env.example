# ──────────────────────────────────────────────
# Servidor
# ──────────────────────────────────────────────
# Puerto en el que escucha Express
PORT=3000

# ──────────────────────────────────────────────
# Base de datos (MongoDB Atlas)
# ──────────────────────────────────────────────
# Connection string de MongoDB — reemplazar <usuario>, <password> y <cluster>
MONGO_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/?appName=fleeswap

# ──────────────────────────────────────────────
# JWT — Access Token
# ──────────────────────────────────────────────
# Clave secreta para firmar el access token (generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=
# Tiempo de vida del access token (se almacena en memoria en el frontend)
JWT_EXPIRES_IN=15m

# ──────────────────────────────────────────────
# JWT — Refresh Token
# ──────────────────────────────────────────────
# Clave secreta para firmar el refresh token (generar igual que JWT_SECRET, pero con un valor distinto)
JWT_REFRESH_SECRET=
# Tiempo de vida del refresh token (formato texto para jsonwebtoken)
JWT_REFRESH_EXPIRES_IN=30d
# Mismo valor en milisegundos — usado para maxAge de la cookie httpOnly
JWT_REFRESH_EXPIRES_IN_MS=2592000000

# ──────────────────────────────────────────────
# Seguridad
# ──────────────────────────────────────────────
# Placeholder usado como hash dummy en login para mitigar timing attacks (no es un secreto real)
BCRYPT_DUMMY_SECRET=fleeswap_dummy_placeholder

# ──────────────────────────────────────────────
# Resend (emails transaccionales)
# ──────────────────────────────────────────────
# API key de Resend — obtener en https://resend.com/api-keys
RESEND_API_KEY=

# ──────────────────────────────────────────────
# Frontend
# ──────────────────────────────────────────────
# URL del frontend — usada para CORS y links en emails (ej: reset password)
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Cloudinary (almacenamiento de imágenes)
# ──────────────────────────────────────────────
# Credenciales de Cloudinary — obtener en https://console.cloudinary.com/settings
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
